# Copy this file to .env and fill in your values before running docker-compose up.
# The .env file is gitignored and must NOT be committed to source control.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ── JWT ─────────────────────────────────────────────────────────────────────
# Must be at least 32 characters.  Generate with: openssl rand -base64 32
JWT_KEY=REPLACE_WITH_STRONG_SECRET_KEY_AT_LEAST_32_CHARACTERS

# ── Elasticsearch ────────────────────────────────────────────────────────────
# Password for the built-in `elastic` superuser.
ELASTIC_PASSWORD=GENERATE_STRONG_PASSWORD_HERE

# ── Kibana ───────────────────────────────────────────────────────────────────
# Password for the dedicated `kibana_system` built-in user.
# Set this to the same value (or different) from ELASTIC_PASSWORD.
KIBANA_SYSTEM_PASSWORD=GENERATE_STRONG_PASSWORD_HERE

# Encryption key used by Kibana for saved objects / session cookies.
# Must be at least 32 characters.  Generate with: openssl rand -hex 16
KIBANA_ENCRYPTION_KEY=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4
